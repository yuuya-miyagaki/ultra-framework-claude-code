{
  "playwright": {
    "command": "npx",
    "args": [
      "-y", "@playwright/mcp@latest",
      "--headless",
      "--codegen", "none",
      "--image-responses", "omit",
      "--block-service-workers",
      "--console-level", "error",
      "--viewport-size", "1280x720"
    ],
    "description": "Browser QA and UI verification via Playwright MCP. Metadata field — ignored by Claude Code.",
    "recommended_phase": ["qa"]
  }
}
