{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/check-gate.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/check-tdd.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/check-client-info.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/check-control-plane.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/check-destructive.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/check-secrets.sh"
          },
          {
            "type": "command",
            "command": "bash hooks/check-deploy-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-bash.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-status-audit.sh",
            "if": "Edit(*STATUS.md) || Write(*STATUS.md) || NotebookEdit(*STATUS.md)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
